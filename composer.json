{
  "name": "tuhuellavet/sistema-veterinario-ganadero",
  "description": "Base MVC para sistema veterinario y ganadero multiempresa",
  "type": "project",
  "require": {
    "php": "^8.1",
    "vlucas/phpdotenv": "^5.6",
    "symfony/expression-language": "^7.1",
    "dompdf/dompdf": "^3.0",
    "phpoffice/phpspreadsheet": "^2.1"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    },
    "files": [
      "app/helpers/app.php"
    ]
  },
  "scripts": {
    "post-install-cmd": [
      "@php -r \"if (!file_exists('.env') && file_exists('.env.example')) copy('.env.example', '.env');\""
    ],
    "post-update-cmd": [
      "@composer dump-autoload"
    ]
  }
}
